# ========================
# Application Config
# ========================
PORT=3000
NODE_ENV=development
API_VERSION=v1
ALLOWED_ORIGINS=http://localhost:5173
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ========================
# Database Config
# ========================
DATABASE_URL=postgresql://closedloop:closedloop_dev@localhost:5432/closedloop_db

# ========================
# Better Auth
# ========================
BETTER_AUTH_SECRET=your-secret-here-change-in-production
BETTER_AUTH_URL=http://localhost:3000

# ========================
# Swagger Config
# ========================
SWAGGER_TITLE=ClosedLoop API
SWAGGER_DESCRIPTION=Closed-loop payment system for festivals
SWAGGER_VERSION=1.0
SWAGGER_PATH=api/docs
SWAGGER_ENABLED=true

# ========================
# Payments Config
# ========================
# Provider driver. Only stripe is implemented right now, but the rest of the
# system talks to a generic PaymentProvider so adding paypal / adyen / etc.
# is just a new adapter file.
PAYMENTS_PROVIDER=stripe
# ISO 4217 currency code (lowercase). All amounts are in minor units (cents).
PAYMENTS_CURRENCY=eur

# ========================
# Stripe (payments provider)
# ========================
# Get these from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook signing secret. Run `stripe listen --forward-to localhost:3000/api/v1/payments/webhook`
# and copy the whsec_... value it prints.
STRIPE_WEBHOOK_SECRET=whsec_...
