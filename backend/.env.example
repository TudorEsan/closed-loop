# ========================
# Application Config
# ========================
PORT=3000
NODE_ENV=development
API_VERSION=v1
ALLOWED_ORIGINS=http://localhost:5173
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ========================
# Database Config
# ========================
DATABASE_URL=postgresql://closedloop:closedloop_dev@localhost:5432/closedloop_db

# ========================
# Better Auth
# ========================
BETTER_AUTH_SECRET=your-secret-here-change-in-production
BETTER_AUTH_URL=http://localhost:3000

# ========================
# Swagger Config
# ========================
SWAGGER_TITLE=ClosedLoop API
SWAGGER_DESCRIPTION=Closed-loop payment system for festivals
SWAGGER_VERSION=1.0
SWAGGER_PATH=api/docs
SWAGGER_ENABLED=true
